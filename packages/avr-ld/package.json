{
  "name": "@binutils-wasm/avr-ld",
  "version": "0.1.0",
  "description": "AVR GNU Linker (ld) with avr-libc compiled to WebAssembly",
  "repository": {
    "type": "git",
    "url": "https://github.com/begeistert/avr-wasm.git",
    "directory": "packages/avr-ld"
  },
  "homepage": "https://github.com/begeistert/avr-wasm#readme",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "build/dist"
  ],
  "scripts": {
    "build:wrapper": "tsup",
    "build:wasm": "node ./build/dist.mjs",
    "build": "pnpm run build:wasm && pnpm run build:wrapper",
    "prebuild": "rm -rf ./build/dist"
  },
  "keywords": [
    "avr",
    "avr-libc",
    "binutils",
    "ld",
    "linker",
    "wasm",
    "webassembly"
  ],
  "author": "",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
